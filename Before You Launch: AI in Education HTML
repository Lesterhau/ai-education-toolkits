<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The High School AI Readiness Toolkit | For ISD Superintendents & Principals</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1A1423;
    --orange: #F5740A;
    --orange-light: #FEF0E6;
    --teal: #00897B;
    --teal-light: #E0F2F1;
    --paper: #FBF7F0;
    --cream: #F5F0E8;
    --gold: #D4940A;
    --gold-light: #FDF6E3;
    --red: #C0392B;
    --red-light: #FDECEA;
    --border: #DDD8CF;
    --gray-text: #5A534A;
    --gray-light: #F0EDE8;
    --white: #FFFFFF;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: 'DM Sans', sans-serif; background: var(--paper); color: var(--ink); font-size: 16px; line-height: 1.7; }

  /* NAV */
  nav {
    position: sticky; top: 0; z-index: 100;
    background: var(--ink); padding: 0 2rem;
    display: flex; align-items: center; gap: 0;
    overflow-x: auto; scrollbar-width: none;
    border-bottom: 3px solid var(--orange);
  }
  nav::-webkit-scrollbar { display: none; }
  .nav-brand { font-family: 'DM Serif Display', serif; color: var(--orange); font-size: 0.9rem; white-space: nowrap; padding: 1rem 1.5rem 1rem 0; border-right: 1px solid rgba(255,255,255,0.12); margin-right: 1rem; }
  nav a { color: rgba(255,255,255,0.65); text-decoration: none; font-size: 0.75rem; font-weight: 500; white-space: nowrap; padding: 1rem 0.9rem; letter-spacing: 0.04em; text-transform: uppercase; transition: color 0.2s; }
  nav a:hover { color: var(--orange); }

  /* HERO */
  .hero { background: var(--ink); color: white; padding: 5rem 3rem 4.5rem; position: relative; overflow: hidden; }
  .hero::after { content: 'HIGH SCHOOL'; position: absolute; right: -2rem; top: 50%; transform: translateY(-50%) rotate(90deg); font-family: 'DM Serif Display', serif; font-size: 8rem; color: rgba(255,255,255,0.03); white-space: nowrap; pointer-events: none; }
  .hero-tag { display: inline-block; background: var(--orange); color: white; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; padding: 0.35rem 0.8rem; border-radius: 2px; margin-bottom: 1.5rem; font-family: 'DM Mono', monospace; }
  .hero h1 { font-family: 'DM Serif Display', serif; font-size: clamp(2.5rem, 5.5vw, 5rem); line-height: 1.05; max-width: 850px; margin-bottom: 1.5rem; }
  .hero h1 em { color: var(--orange); font-style: normal; }
  .hero-sub { font-size: 1.1rem; color: rgba(255,255,255,0.62); max-width: 650px; font-weight: 300; line-height: 1.7; margin-bottom: 2.5rem; }
  .hero-badges { display: flex; gap: 1rem; flex-wrap: wrap; }
  .hero-badge { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 3px; padding: 0.5rem 1rem; font-size: 0.78rem; color: rgba(255,255,255,0.7); font-family: 'DM Mono', monospace; }

  /* ALERT */
  .alert-bar { background: var(--orange); color: white; padding: 1.1rem 3rem; font-size: 0.9rem; font-weight: 600; }
  .alert-bar span { opacity: 0.85; font-weight: 400; }

  /* LAYOUT */
  .page-wrap { max-width: 1060px; margin: 0 auto; padding: 0 2.5rem; }
  section { padding: 5rem 0; }
  section + section { border-top: 1px solid var(--border); }

  /* TYPOGRAPHY */
  .eyebrow { font-family: 'DM Mono', monospace; font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--orange); font-weight: 500; margin-bottom: 0.8rem; display: block; }
  h2 { font-family: 'DM Serif Display', serif; font-size: clamp(1.9rem, 3.5vw, 2.8rem); line-height: 1.15; color: var(--ink); margin-bottom: 1.2rem; }
  h3 { font-family: 'DM Serif Display', serif; font-size: 1.5rem; color: var(--ink); margin-bottom: 0.9rem; }
  h4 { font-size: 0.82rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--gray-text); margin-bottom: 0.7rem; }
  p { color: var(--gray-text); line-height: 1.8; margin-bottom: 1.1rem; }
  p:last-child { margin-bottom: 0; }
  strong { color: var(--ink); }

  /* STAT GRID */
  .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.2rem; margin: 2.5rem 0; }
  .stat-card { background: var(--white); border: 1px solid var(--border); border-radius: 3px; padding: 1.8rem 1.5rem; border-top: 4px solid var(--orange); }
  .stat-card.teal { border-top-color: var(--teal); }
  .stat-card.red { border-top-color: var(--red); }
  .stat-card.gold { border-top-color: var(--gold); }
  .stat-num { font-family: 'DM Serif Display', serif; font-size: 3rem; line-height: 1; color: var(--ink); margin-bottom: 0.4rem; }
  .stat-desc { font-size: 0.85rem; color: var(--gray-text); line-height: 1.5; }
  .stat-src { font-family: 'DM Mono', monospace; font-size: 0.65rem; color: var(--border); margin-top: 0.8rem; display: block; }

  /* CALLOUT */
  .callout { border-left: 4px solid var(--orange); background: var(--cream); padding: 1.8rem 2rem; margin: 2rem 0; border-radius: 0 3px 3px 0; }
  .callout.teal { border-color: var(--teal); }
  .callout.red { border-color: var(--red); }
  .callout.gold { border-color: var(--gold); }
  .callout.dark { border-color: var(--orange); background: var(--ink); }
  .callout.dark p, .callout.dark .callout-text { color: rgba(255,255,255,0.8); }
  .callout.dark .callout-source { color: var(--orange); }
  .callout-text { font-family: 'DM Serif Display', serif; font-size: 1.15rem; font-style: italic; color: var(--ink); line-height: 1.6; margin-bottom: 0.7rem; }
  .callout-source { font-family: 'DM Mono', monospace; font-size: 0.7rem; letter-spacing: 0.08em; color: var(--gray-text); text-transform: uppercase; }

  /* UNKNOWN BOX */
  .unknown-box { background: var(--gold-light); border: 1px solid var(--gold); border-left: 4px solid var(--gold); border-radius: 3px; padding: 1.5rem 2rem; margin: 2rem 0; }
  .unknown-box h4 { color: var(--gold); margin-bottom: 0.5rem; }
  .unknown-box p { color: #6B5800; font-size: 0.9rem; margin-bottom: 0; }

  /* ACTION BLOCK */
  .action-block { background: var(--white); border: 1px solid var(--border); border-radius: 3px; margin: 1.5rem 0; overflow: hidden; }
  .action-header { padding: 1.2rem 1.8rem; background: var(--orange); color: white; display: flex; align-items: center; gap: 1rem; }
  .action-header.teal { background: var(--teal); }
  .action-header.red { background: var(--red); }
  .action-header.ink { background: var(--ink); }
  .action-header.gold { background: var(--gold); }
  .action-icon { font-size: 1.5rem; }
  .action-title { font-family: 'DM Serif Display', serif; font-size: 1.1rem; color: white; margin: 0; }
  .action-sub { font-size: 0.78rem; color: rgba(255,255,255,0.72); margin-top: 0.1rem; font-weight: 300; }
  .action-body { padding: 1.8rem; }

  /* CHECKLIST */
  .checklist { list-style: none; display: flex; flex-direction: column; gap: 0; }
  .checklist li { display: flex; gap: 1.2rem; align-items: flex-start; padding: 1rem 0; border-bottom: 1px solid var(--gray-light); cursor: pointer; transition: background 0.15s; border-radius: 2px; }
  .checklist li:last-child { border-bottom: none; }
  .checklist li:hover { background: var(--gray-light); padding-left: 0.5rem; padding-right: 0.5rem; margin: 0 -0.5rem; }
  .check-box { width: 22px; height: 22px; border: 2px solid var(--border); border-radius: 3px; flex-shrink: 0; margin-top: 2px; background: white; transition: all 0.15s; cursor: pointer; display: flex; align-items: center; justify-content: center; }
  .check-box.checked { background: var(--teal); border-color: var(--teal); }
  .check-box.checked::after { content: '✓'; color: white; font-size: 0.75rem; font-weight: 700; }
  .check-content strong { display: block; font-size: 0.95rem; font-weight: 600; color: var(--ink); line-height: 1.4; margin-bottom: 0.3rem; }
  .check-why { font-size: 0.82rem; color: var(--gray-text); line-height: 1.55; }
  .check-why em { color: var(--orange); font-style: normal; font-weight: 600; }

  /* PILL TAGS */
  .pill { display: inline-block; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.2rem 0.55rem; border-radius: 2px; margin-right: 0.4rem; font-family: 'DM Mono', monospace; vertical-align: middle; }
  .pill.add { background: #E8F5E9; color: #1B5E20; }
  .pill.dissolve { background: var(--red-light); color: var(--red); }
  .pill.reform { background: var(--gold-light); color: #7B5800; }
  .pill.required { background: #E3F2FD; color: #0D47A1; }

  /* SUBJECT GRID */
  .subject-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.2rem; margin: 2rem 0; }
  .subject-card { background: var(--white); border: 1px solid var(--border); border-radius: 3px; padding: 1.5rem; }
  .subject-name { font-family: 'DM Serif Display', serif; font-size: 1.05rem; color: var(--ink); margin-bottom: 0.8rem; border-bottom: 2px solid var(--orange); padding-bottom: 0.5rem; display: inline-block; }
  .subject-card ul { list-style: none; }
  .subject-card ul li { font-size: 0.83rem; color: var(--gray-text); padding: 0.4rem 0 0.4rem 1rem; position: relative; border-bottom: 1px solid var(--gray-light); line-height: 1.5; }
  .subject-card ul li:last-child { border-bottom: none; }
  .subject-card ul li::before { content: '→'; position: absolute; left: 0; color: var(--orange); font-size: 0.75rem; top: 0.5rem; }

  /* SCIENCE OF LEARNING */
  .sol-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); gap: 1.2rem; margin: 2rem 0; }
  .sol-card { background: var(--white); border: 1px solid var(--border); border-radius: 3px; padding: 1.6rem; position: relative; }
  .sol-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--teal); }
  .sol-number { font-family: 'DM Mono', monospace; font-size: 0.65rem; color: var(--teal); font-weight: 500; letter-spacing: 0.1em; margin-bottom: 0.4rem; text-transform: uppercase; }
  .sol-card h4 { text-transform: none; letter-spacing: 0; font-size: 0.97rem; font-weight: 700; color: var(--ink); margin-bottom: 0.6rem; }
  .sol-card p { font-size: 0.84rem; color: var(--gray-text); margin-bottom: 0.8rem; }
  .sol-card .apply { font-size: 0.8rem; background: var(--teal-light); border-left: 3px solid var(--teal); padding: 0.6rem 0.8rem; color: #004D40; border-radius: 0 2px 2px 0; }
  .apply strong { color: var(--teal); display: block; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.2rem; }

  /* TIMELINE */
  .timeline-wrap { position: relative; padding: 1rem 0; margin: 2rem 0; }
  .timeline-wrap::before { content: ''; position: absolute; left: 90px; top: 0; bottom: 0; width: 2px; background: var(--border); }
  .tl-row { display: grid; grid-template-columns: 90px 1fr; gap: 2rem; margin-bottom: 2rem; position: relative; }
  .tl-period { text-align: right; padding-top: 0.3rem; position: relative; }
  .tl-period::after { content: ''; position: absolute; right: -2.6rem; top: 0.45rem; width: 14px; height: 14px; border-radius: 50%; background: var(--orange); border: 3px solid var(--paper); box-shadow: 0 0 0 2px var(--orange); }
  .tl-row.teal .tl-period::after { background: var(--teal); box-shadow: 0 0 0 2px var(--teal); }
  .tl-row.gold .tl-period::after { background: var(--gold); box-shadow: 0 0 0 2px var(--gold); }
  .tl-row.ink .tl-period::after { background: var(--ink); box-shadow: 0 0 0 2px var(--ink); }
  .tl-label { font-family: 'DM Mono', monospace; font-size: 0.68rem; font-weight: 500; color: var(--orange); text-transform: uppercase; letter-spacing: 0.06em; line-height: 1.3; }
  .tl-row.teal .tl-label { color: var(--teal); }
  .tl-row.gold .tl-label { color: var(--gold); }
  .tl-row.ink .tl-label { color: var(--ink); }
  .tl-content { background: var(--white); border: 1px solid var(--border); border-radius: 3px; padding: 1.3rem 1.5rem; }
  .tl-content h4 { text-transform: none; letter-spacing: 0; font-size: 0.95rem; font-weight: 700; color: var(--ink); margin-bottom: 0.5rem; }
  .tl-content ul { list-style: none; }
  .tl-content ul li { font-size: 0.83rem; color: var(--gray-text); padding: 0.35rem 0 0.35rem 1rem; position: relative; border-bottom: 1px solid var(--gray-light); line-height: 1.5; }
  .tl-content ul li:last-child { border-bottom: none; }
  .tl-content ul li::before { content: '→'; position: absolute; left: 0; color: var(--orange); font-size: 0.72rem; top: 0.45rem; }

  /* JOB DESCRIPTION */
  .job-box { background: var(--ink); color: white; border-radius: 3px; padding: 2.5rem; margin: 2rem 0; }
  .job-box h3 { color: var(--orange); font-size: 1.2rem; margin-bottom: 0.3rem; }
  .job-box .job-title { font-family: 'DM Mono', monospace; font-size: 0.72rem; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1.5rem; }
  .job-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 1.5rem; }
  .job-col h4 { color: var(--orange); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.6rem; }
  .job-col ul { list-style: none; }
  .job-col ul li { font-size: 0.83rem; color: rgba(255,255,255,0.72); padding: 0.3rem 0 0.3rem 1rem; position: relative; border-bottom: 1px solid rgba(255,255,255,0.06); line-height: 1.5; }
  .job-col ul li:last-child { border-bottom: none; }
  .job-col ul li::before { content: '·'; position: absolute; left: 0; color: var(--orange); }

  /* RESOURCES */
  .resource-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.2rem; margin: 2rem 0; }
  .resource-card { background: var(--white); border: 1px solid var(--border); border-radius: 3px; padding: 1.4rem; }
  .resource-card h4 { text-transform: none; letter-spacing: 0; font-size: 0.9rem; font-weight: 700; color: var(--ink); margin-bottom: 0.3rem; }
  .resource-card .resource-type { font-family: 'DM Mono', monospace; font-size: 0.65rem; color: var(--teal); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.6rem; display: block; }
  .resource-card .resource-url { font-family: 'DM Mono', monospace; font-size: 0.7rem; color: var(--orange); display: block; margin-top: 0.5rem; word-break: break-all; }
  .resource-card p { font-size: 0.82rem; color: var(--gray-text); margin: 0; line-height: 1.5; }
  .resource-card .cost { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.15rem 0.4rem; border-radius: 2px; font-family: 'DM Mono', monospace; }
  .cost.free { background: #E8F5E9; color: #1B5E20; }
  .cost.paid { background: var(--red-light); color: var(--red); }
  .cost.freemium { background: var(--gold-light); color: #7B5800; }

  /* POLICY ZONES */
  .zone-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin: 2rem 0; }
  .zone-card { border-radius: 3px; padding: 1.5rem; text-align: center; }
  .zone-card.z1 { background: var(--red-light); border: 1px solid var(--red); }
  .zone-card.z2 { background: var(--gold-light); border: 1px solid var(--gold); }
  .zone-card.z3 { background: var(--teal-light); border: 1px solid var(--teal); }
  .zone-number { font-family: 'DM Serif Display', serif; font-size: 2.5rem; font-weight: 900; margin-bottom: 0.3rem; }
  .z1 .zone-number { color: var(--red); }
  .z2 .zone-number { color: var(--gold); }
  .z3 .zone-number { color: var(--teal); }
  .zone-name { font-weight: 700; font-size: 0.9rem; margin-bottom: 0.5rem; }
  .zone-card p { font-size: 0.8rem; color: var(--gray-text); margin: 0; }
  .zone-examples { font-size: 0.75rem; margin-top: 0.8rem; font-style: italic; color: var(--gray-text); }

  /* REPEAT CYCLE */
  .cycle-box { background: var(--cream); border: 1px solid var(--border); border-radius: 3px; padding: 2rem; margin: 2rem 0; }
  .cycle-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-top: 1.5rem; }
  .cycle-item { background: var(--white); border: 1px solid var(--border); border-radius: 3px; padding: 1.2rem; text-align: center; }
  .cycle-quarter { font-family: 'DM Mono', monospace; font-size: 0.68rem; color: var(--orange); font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.4rem; }
  .cycle-item h4 { text-transform: none; letter-spacing: 0; font-size: 0.85rem; font-weight: 700; color: var(--ink); margin-bottom: 0.4rem; }
  .cycle-item p { font-size: 0.75rem; color: var(--gray-text); margin: 0; line-height: 1.4; }

  /* BIG QUOTE */
  .big-quote { font-family: 'DM Serif Display', serif; font-size: clamp(1.4rem, 2.5vw, 2rem); font-style: italic; color: var(--ink); border-top: 3px solid var(--orange); border-bottom: 3px solid var(--orange); padding: 2rem 0; margin: 3rem 0; line-height: 1.5; }

  /* FOOTER */
  footer { background: var(--ink); color: rgba(255,255,255,0.55); padding: 3.5rem 0 2rem; font-size: 0.82rem; line-height: 1.8; }
  .footer-inner { max-width: 1060px; margin: 0 auto; padding: 0 2.5rem; }
  .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 2.5rem; margin-bottom: 2.5rem; }
  footer h4 { color: white; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.8rem; }
  footer a { color: var(--orange); text-decoration: none; }
  .footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 1.5rem; font-size: 0.72rem; color: rgba(255,255,255,0.3); }

  /* UTILS */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .highlight { background: var(--orange); color: white; display: inline; padding: 0 0.2rem; }
  .warn-box { background: var(--red-light); border: 1px solid var(--red); border-radius: 3px; padding: 1.5rem 1.8rem; margin: 1.5rem 0; }
  .warn-box p { color: var(--red); margin: 0; font-size: 0.9rem; font-weight: 500; }
  .progress-note { background: var(--teal-light); border-left: 4px solid var(--teal); padding: 1rem 1.5rem; border-radius: 0 3px 3px 0; margin: 1.5rem 0; font-size: 0.88rem; color: #004D40; }

  @media (max-width: 768px) {
    .two-col { grid-template-columns: 1fr; }
    .zone-grid { grid-template-columns: 1fr; }
    .job-grid { grid-template-columns: 1fr; }
    .cycle-grid { grid-template-columns: 1fr 1fr; }
    .timeline-wrap::before { left: 70px; }
    .tl-row { grid-template-columns: 70px 1fr; }
    .tl-period::after { right: -2.1rem; }
    section { padding: 3.5rem 0; }
    .hero { padding: 3.5rem 1.5rem 3rem; }
    .page-wrap { padding: 0 1.5rem; }
    .alert-bar { padding: 1rem 1.5rem; }
    nav { padding: 0 1rem; }
  }
  @media print {
    nav { display: none !important; }
    .action-block, .callout, .zone-card, .stat-card, .unknown-box,
    .progress-note, .warn-box, .job-box, .two-col, .checklist li,
    .alert-bar > div, section > div { break-inside: avoid; }
    h2, h3, .eyebrow, .action-header, .action-title { break-after: avoid; }
    footer, footer * { color: white !important; print-color-adjust: exact; -webkit-print-color-adjust: exact; }
    footer a { color: #F5740A !important; }
    * { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
  }
</style>
</head>

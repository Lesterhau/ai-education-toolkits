<style>
  :root {
    --forest: #1B3A2A;
    --forest-mid: #2D5940;
    --gold: #C9A227;
    --gold-light: #FBF5E0;
    --cream: #FAF7F0;
    --warm: #F3EDE1;
    --paper: #FEFCF8;
    --charcoal: #2C2C2C;
    --rust: #B04A2A;
    --rust-light: #FAEAE5;
    --slate: #4A5568;
    --border: #DDD5C5;
    --gray-light: #F0EBE0;
    --white: #FFFFFF;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Source Sans 3', sans-serif; background: var(--cream); color: var(--charcoal); font-size: 16px; line-height: 1.7; }

  /* NAV */
  nav { position: sticky; top: 0; z-index: 100; background: var(--forest); padding: 0 2.5rem; display: flex; align-items: center; overflow-x: auto; scrollbar-width: none; }
  nav::-webkit-scrollbar { display: none; }
  .nav-brand { font-family: 'Cormorant Garamond', serif; color: var(--gold); font-size: 1rem; font-weight: 700; white-space: nowrap; padding: 1rem 1.8rem 1rem 0; border-right: 1px solid rgba(255,255,255,0.1); margin-right: 1.5rem; letter-spacing: 0.02em; }
  nav a { color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.74rem; font-weight: 500; white-space: nowrap; padding: 1rem 0.9rem; letter-spacing: 0.06em; text-transform: uppercase; transition: color 0.2s; }
  nav a:hover { color: var(--gold); }

  /* HERO */
  .hero { background: var(--forest); color: white; padding: 6rem 3rem 5rem; position: relative; overflow: hidden; }
  .hero::before { content: ''; position: absolute; top: 0; right: 0; bottom: 0; width: 40%; background: linear-gradient(135deg, transparent 40%, rgba(201,162,39,0.06) 100%); pointer-events: none; }
  .hero-kicker { font-family: 'Source Code Pro', monospace; font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.5rem; display: block; }
  .hero h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.8rem, 6vw, 5.5rem); font-weight: 600; line-height: 1.08; max-width: 850px; margin-bottom: 1.5rem; }
  .hero h1 em { color: var(--gold); font-style: italic; }
  .hero-sub { font-size: 1.1rem; color: rgba(255,255,255,0.6); max-width: 640px; font-weight: 300; line-height: 1.75; margin-bottom: 3rem; }
  .hero-rule { width: 60px; height: 3px; background: var(--gold); margin-bottom: 2rem; }
  .hero-sources { font-family: 'Source Code Pro', monospace; font-size: 0.68rem; color: rgba(255,255,255,0.35); line-height: 2; }

  /* MANDATE BAR */
  .mandate-bar { background: var(--gold); color: var(--forest); padding: 1.2rem 3rem; font-weight: 700; font-size: 0.9rem; }
  .mandate-bar span { font-weight: 400; }

  /* LAYOUT */
  .page-wrap { max-width: 1080px; margin: 0 auto; padding: 0 3rem; }
  section { padding: 5.5rem 0; }
  section + section { border-top: 1px solid var(--border); }

  /* TYPOGRAPHY */
  .eyebrow { font-family: 'Source Code Pro', monospace; font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; display: block; }
  h2 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 600; line-height: 1.15; color: var(--forest); margin-bottom: 1.3rem; }
  h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.65rem; font-weight: 600; color: var(--forest); margin-bottom: 0.9rem; }
  h4 { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--slate); margin-bottom: 0.7rem; }
  p { color: var(--slate); line-height: 1.85; margin-bottom: 1.1rem; }
  p:last-child { margin-bottom: 0; }
  strong { color: var(--charcoal); }

  /* STATS */
  .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 1.2rem; margin: 2.5rem 0; }
  .stat-card { background: var(--white); border: 1px solid var(--border); padding: 1.8rem 1.6rem; position: relative; }
  .stat-card::after { content: ''; position: absolute; top: 0; left: 0; bottom: 0; width: 4px; background: var(--gold); }
  .stat-card.forest::after { background: var(--forest); }
  .stat-card.rust::after { background: var(--rust); }
  .stat-num { font-family: 'Cormorant Garamond', serif; font-size: 3.2rem; font-weight: 700; color: var(--forest); line-height: 1; margin-bottom: 0.4rem; }
  .stat-desc { font-size: 0.85rem; color: var(--slate); line-height: 1.55; }
  .stat-src { font-family: 'Source Code Pro', monospace; font-size: 0.63rem; color: var(--border); margin-top: 0.8rem; display: block; }

  /* CALLOUT */
  .callout { border-left: 3px solid var(--gold); background: var(--gold-light); padding: 1.8rem 2rem; margin: 2rem 0; }
  .callout.forest { border-color: var(--forest); background: #EDF2EE; }
  .callout.rust { border-color: var(--rust); background: var(--rust-light); }
  .callout.dark { border-color: var(--gold); background: var(--forest); }
  .callout.dark .callout-text { color: rgba(255,255,255,0.9); }
  .callout.dark .callout-src { color: var(--gold); }
  .callout-text { font-family: 'Cormorant Garamond', serif; font-size: 1.25rem; font-style: italic; color: var(--forest); line-height: 1.6; margin-bottom: 0.6rem; }
  .callout-src { font-family: 'Source Code Pro', monospace; font-size: 0.68rem; letter-spacing: 0.06em; color: var(--slate); text-transform: uppercase; }

  /* UNKNOWN */
  .unknown-box { background: var(--gold-light); border: 1px solid var(--gold); padding: 1.5rem 2rem; margin: 2rem 0; }
  .unknown-box h4 { color: #8B6200; }
  .unknown-box p { color: #6B5000; font-size: 0.88rem; margin: 0; }

  /* ACTION BLOCK */
  .action-block { background: var(--white); border: 1px solid var(--border); margin: 1.8rem 0; }
  .action-header { padding: 1.3rem 2rem; background: var(--forest); color: white; display: flex; align-items: flex-start; gap: 1rem; }
  .action-header.gold { background: var(--gold); }
  .action-header.gold .action-title { color: var(--forest); }
  .action-header.gold .action-sub { color: rgba(0,0,0,0.6); }
  .action-header.rust { background: var(--rust); }
  .action-header.charcoal { background: var(--charcoal); }
  .action-icon { font-size: 1.5rem; flex-shrink: 0; padding-top: 0.1rem; }
  .action-title { font-family: 'Cormorant Garamond', serif; font-size: 1.15rem; font-weight: 600; color: white; margin-bottom: 0.2rem; }
  .action-sub { font-size: 0.78rem; color: rgba(255,255,255,0.65); font-weight: 300; }
  .action-body { padding: 2rem; }

  /* CHECKLIST */
  .checklist { list-style: none; }
  .checklist li { display: flex; gap: 1.2rem; align-items: flex-start; padding: 0.9rem 0; border-bottom: 1px solid var(--gray-light); cursor: pointer; }
  .checklist li:last-child { border-bottom: none; }
  .check-box { width: 20px; height: 20px; border: 2px solid var(--border); flex-shrink: 0; margin-top: 3px; background: white; transition: all 0.15s; cursor: pointer; display: flex; align-items: center; justify-content: center; }
  .check-box.checked { background: var(--forest); border-color: var(--forest); }
  .check-box.checked::after { content: '✓'; color: white; font-size: 0.72rem; font-weight: 700; }
  .check-content strong { display: block; font-size: 0.95rem; font-weight: 600; color: var(--charcoal); margin-bottom: 0.3rem; line-height: 1.4; }
  .check-why { font-size: 0.82rem; color: var(--slate); line-height: 1.6; }

  /* PILLS */
  .pill { display: inline-block; font-size: 0.63rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.18rem 0.5rem; font-family: 'Source Code Pro', monospace; vertical-align: middle; margin-left: 0.4rem; }
  .pill.add { background: #E8F5E9; color: #1B5E20; }
  .pill.dissolve { background: var(--rust-light); color: var(--rust); }
  .pill.reform { background: var(--gold-light); color: #7B5800; }
  .pill.required { background: #E3F2FD; color: #0D47A1; }

  /* TWO-COL */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }

  /* DISCIPLINE GRID */
  .disc-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(270px, 1fr)); gap: 1.2rem; margin: 2rem 0; }
  .disc-card { background: var(--white); border: 1px solid var(--border); padding: 1.5rem; }
  .disc-name { font-family: 'Cormorant Garamond', serif; font-size: 1.05rem; font-weight: 600; color: var(--forest); border-bottom: 2px solid var(--gold); padding-bottom: 0.5rem; margin-bottom: 0.8rem; display: inline-block; }
  .disc-card ul { list-style: none; }
  .disc-card ul li { font-size: 0.82rem; color: var(--slate); padding: 0.38rem 0 0.38rem 1rem; position: relative; border-bottom: 1px solid var(--gray-light); line-height: 1.5; }
  .disc-card ul li:last-child { border-bottom: none; }
  .disc-card ul li::before { content: '→'; position: absolute; left: 0; color: var(--gold); font-size: 0.72rem; top: 0.5rem; }

  /* SCIENCE OF LEARNING */
  .sol-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.2rem; margin: 2rem 0; }
  .sol-card { background: var(--white); border: 1px solid var(--border); padding: 1.6rem; position: relative; }
  .sol-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--forest); }
  .sol-num { font-family: 'Source Code Pro', monospace; font-size: 0.63rem; color: var(--forest-mid); font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.4rem; }
  .sol-card h4 { text-transform: none; letter-spacing: 0; font-size: 0.95rem; font-weight: 700; color: var(--charcoal); margin-bottom: 0.5rem; }
  .sol-card p { font-size: 0.83rem; color: var(--slate); margin-bottom: 0.7rem; }
  .sol-apply { font-size: 0.79rem; background: #EDF2EE; border-left: 3px solid var(--forest); padding: 0.6rem 0.8rem; color: var(--forest); line-height: 1.5; }
  .sol-apply strong { color: var(--forest); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; display: block; margin-bottom: 0.2rem; }

  /* TIMELINE */
  .timeline-wrap { position: relative; padding: 1rem 0; margin: 2rem 0; }
  .timeline-wrap::before { content: ''; position: absolute; left: 90px; top: 0; bottom: 0; width: 2px; background: var(--border); }
  .tl-row { display: grid; grid-template-columns: 90px 1fr; gap: 2rem; margin-bottom: 2rem; }
  .tl-period { text-align: right; padding-top: 0.3rem; position: relative; }
  .tl-period::after { content: ''; position: absolute; right: -2.6rem; top: 0.45rem; width: 14px; height: 14px; border-radius: 50%; background: var(--gold); border: 3px solid var(--cream); box-shadow: 0 0 0 2px var(--gold); }
  .tl-row.forest .tl-period::after { background: var(--forest); box-shadow: 0 0 0 2px var(--forest); }
  .tl-row.rust .tl-period::after { background: var(--rust); box-shadow: 0 0 0 2px var(--rust); }
  .tl-row.charcoal .tl-period::after { background: var(--charcoal); box-shadow: 0 0 0 2px var(--charcoal); }
  .tl-label { font-family: 'Source Code Pro', monospace; font-size: 0.65rem; color: var(--gold); text-transform: uppercase; letter-spacing: 0.06em; line-height: 1.3; }
  .tl-row.forest .tl-label { color: var(--forest); }
  .tl-row.rust .tl-label { color: var(--rust); }
  .tl-row.charcoal .tl-label { color: var(--charcoal); }
  .tl-content { background: var(--white); border: 1px solid var(--border); padding: 1.3rem 1.6rem; }
  .tl-content h4 { text-transform: none; letter-spacing: 0; font-size: 0.95rem; font-weight: 700; color: var(--charcoal); margin-bottom: 0.5rem; }
  .tl-content ul { list-style: none; }
  .tl-content ul li { font-size: 0.82rem; color: var(--slate); padding: 0.33rem 0 0.33rem 1rem; position: relative; border-bottom: 1px solid var(--gray-light); line-height: 1.5; }
  .tl-content ul li:last-child { border-bottom: none; }
  .tl-content ul li::before { content: '→'; position: absolute; left: 0; color: var(--gold); font-size: 0.7rem; top: 0.43rem; }

  /* JOB BOX */
  .job-box { background: var(--forest); color: white; padding: 2.5rem; margin: 2rem 0; }
  .job-box h3 { color: var(--gold); font-size: 1.3rem; margin-bottom: 0.2rem; }
  .job-box .job-title { font-family: 'Source Code Pro', monospace; font-size: 0.68rem; color: rgba(255,255,255,0.45); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1.5rem; display: block; }
  .job-box p { color: rgba(255,255,255,0.7); font-size: 0.88rem; }
  .job-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 1.5rem; }
  .job-col h4 { color: var(--gold); font-size: 0.68rem; margin-bottom: 0.6rem; }
  .job-col ul { list-style: none; }
  .job-col ul li { font-size: 0.82rem; color: rgba(255,255,255,0.7); padding: 0.3rem 0 0.3rem 1rem; position: relative; border-bottom: 1px solid rgba(255,255,255,0.07); line-height: 1.5; }
  .job-col ul li:last-child { border-bottom: none; }
  .job-col ul li::before { content: '·'; position: absolute; left: 0; color: var(--gold); }

  /* POLICY TIERS */
  .tier-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 2rem 0; }
  .tier-card { padding: 1.5rem; border: 1px solid var(--border); background: var(--white); }
  .tier-card.t1 { border-top: 4px solid var(--rust); }
  .tier-card.t2 { border-top: 4px solid var(--gold); }
  .tier-card.t3 { border-top: 4px solid var(--forest); }
  .tier-num { font-family: 'Cormorant Garamond', serif; font-size: 2.5rem; font-weight: 700; margin-bottom: 0.3rem; }
  .t1 .tier-num { color: var(--rust); }
  .t2 .tier-num { color: var(--gold); }
  .t3 .tier-num { color: var(--forest); }
  .tier-name { font-weight: 700; font-size: 0.9rem; margin-bottom: 0.5rem; color: var(--charcoal); }
  .tier-card p { font-size: 0.8rem; color: var(--slate); margin: 0; line-height: 1.5; }
  .tier-examples { font-size: 0.74rem; color: var(--slate); margin-top: 0.8rem; font-style: italic; }

  /* RESOURCES */
  .resource-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(270px, 1fr)); gap: 1.2rem; margin: 2rem 0; }
  .resource-card { background: var(--white); border: 1px solid var(--border); padding: 1.4rem; }
  .resource-card h4 { text-transform: none; letter-spacing: 0; font-size: 0.9rem; font-weight: 700; color: var(--charcoal); margin-bottom: 0.3rem; }
  .resource-card .res-type { font-family: 'Source Code Pro', monospace; font-size: 0.62rem; color: var(--forest-mid); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem; display: block; }
  .resource-card .res-url { font-family: 'Source Code Pro', monospace; font-size: 0.68rem; color: var(--gold); display: block; margin-top: 0.5rem; word-break: break-all; }
  .resource-card p { font-size: 0.81rem; color: var(--slate); margin: 0; line-height: 1.5; }
  .cost { font-size: 0.62rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.12rem 0.4rem; font-family: 'Source Code Pro', monospace; }
  .cost.free { background: #E8F5E9; color: #1B5E20; }
  .cost.paid { background: var(--rust-light); color: var(--rust); }
  .cost.freemium { background: var(--gold-light); color: #7B5800; }

  /* BIG QUOTE */
  .big-quote { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.5rem, 2.8vw, 2.1rem); font-style: italic; color: var(--forest); border-top: 2px solid var(--gold); border-bottom: 2px solid var(--gold); padding: 2rem 0; margin: 3rem 0; line-height: 1.5; }

  /* ACRED BOX */
  .accred-box { background: var(--rust-light); border: 1px solid var(--rust); padding: 2rem; margin: 2rem 0; }
  .accred-box h4 { color: var(--rust); margin-bottom: 0.6rem; }
  .accred-box p { color: #6B2E1A; font-size: 0.88rem; }

  /* PROGRESS NOTE */
  .progress-note { background: #EDF2EE; border-left: 4px solid var(--forest); padding: 1rem 1.5rem; margin: 1.5rem 0; font-size: 0.87rem; color: var(--forest); }

  /* WARN */
  .warn-box { background: var(--rust-light); border: 1px solid var(--rust); padding: 1.3rem 1.8rem; margin: 1.5rem 0; }
  .warn-box p { color: var(--rust); font-size: 0.88rem; font-weight: 500; margin: 0; }

  /* FOOTER */
  footer { background: var(--forest); color: rgba(255,255,255,0.55); padding: 4rem 0 2rem; font-size: 0.82rem; line-height: 1.85; }
  .footer-inner { max-width: 1080px; margin: 0 auto; padding: 0 3rem; }
  .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 2.5rem; margin-bottom: 2.5rem; }
  footer h4 { color: white; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.8rem; }
  footer a { color: var(--gold); text-decoration: none; }
  .footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 1.5rem; font-size: 0.7rem; color: rgba(255,255,255,0.28); }

  @media (max-width: 768px) {
    .two-col { grid-template-columns: 1fr; }
    .tier-grid { grid-template-columns: 1fr; }
    .job-grid { grid-template-columns: 1fr; }
    .timeline-wrap::before { left: 68px; }
    .tl-row { grid-template-columns: 68px 1fr; }
    .tl-period::after { right: -2.1rem; }
    section { padding: 3.5rem 0; }
    .hero { padding: 4rem 1.5rem 3.5rem; }
    .page-wrap { padding: 0 1.5rem; }
    .mandate-bar { padding: 1rem 1.5rem; }
    nav { padding: 0 1rem; }
  }
  @media print {
    nav { display: none !important; }
    .action-block, .callout, .tier-card, .stat-card, .unknown-box,
    .progress-note, .warn-box, .job-box, .two-col, .checklist li,
    .accred-card { break-inside: avoid; }
    h2, h3, .eyebrow, .action-header, .action-title { break-after: avoid; }
    footer, footer * { color: white !important; print-color-adjust: exact; -webkit-print-color-adjust: exact; }
    footer a { color: var(--gold) !important; }
    * { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
  }
</style>
</head>
